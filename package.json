{
  "name": "desktop-todo-widget",
  "version": "0.1.3",
  "description": "A Windows desktop todo widget with global quick add and daily rollover.",
  "private": true,
  "type": "module",
  "main": "./out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder",
    "dist:publish": "npm run build && electron-builder --publish always",
    "test": "vitest run",
    "diagnose:desktop": "node scripts/diagnose-desktop-attach.cjs"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "koffi": "^3.1.0",
    "lucide-react": "^1.23.0",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "5.1.4",
    "electron": "latest",
    "electron-builder": "latest",
    "electron-vite": "5.0.0",
    "typescript": "latest",
    "vite": "7.3.6",
    "vitest": "latest"
  },
  "build": {
    "appId": "com.local.desktop-todo-widget",
    "productName": "Desktop Todo Widget",
    "icon": "build/icon.png",
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Anda1231",
        "repo": "TODO"
      }
    ]
  }
}
